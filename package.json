{
  "name": "cvr-amp-controller-web",
  "version": "0.1.0",
  "description": "CVR AMP Controller — desktop app for managing CVR amplifier devices",
  "author": "scalli007",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "concurrently -k -n next,electron -c cyan,yellow \"next dev -p 3000\" \"cross-env ELECTRON_DEV=1 electron .\"",
    "electron:build": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\" && next build && electron-builder --win",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "build": {
    "appId": "com.cvr.ampcontroller",
    "productName": "CVR AMP Controller",
    "icon": "public/logo.ico",
    "asar": true,
    "asarUnpack": [
      "node_modules/**/*.node"
    ],
    "files": [
      "electron/**/*",
      ".next/**/*",
      "public/**/*",
      "storage/**/*",
      "package.json",
      "!.next/cache/**/*",
      "!.next/dev/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/logo.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "public/logo.ico",
      "uninstallerIcon": "public/logo.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/logo.ico"
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@formatjs/intl-localematcher": "^0.8.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "negotiator": "^1.0.0",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "2.15.4",
    "shadcn": "^3.8.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/negotiator": "^0.6.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  }
}
